{
   "name": "portfolio-server",
   "version": "1.0.0",
   "description": "Backend server for portfolio application",
   "main": "src/app.ts",
   "scripts": {
      "start": "node dist/app.js",
      "dev": "nodemon --exec ts-node src/app.ts",
      "prebuild": "sed -i \"s/^VITE_GIT_COMMIT_DATE=.*/VITE_GIT_COMMIT_DATE=\\\"$(git log -1 --format=%cd --date=iso-strict)\\\"/\" .env",
      "build": "tsc",
      "test": "jest",
      "lint": "eslint . --ext .ts"
   },
   "dependencies": {
      "@supabase/supabase-js": "^2.x",
      "cors": "^2.8.5",
      "dotenv": "^16.x",
      "express": "^4.x",
      "express-validator": "^7.x",
      "helmet": "^7.x",
      "morgan": "^1.x"
   },
   "devDependencies": {
      "@playwright/test": "^1.54.2",
      "@types/cors": "^2.x",
      "@types/express": "^4.x",
      "@types/jest": "^29.x",
      "@types/morgan": "^1.x",
      "@types/node": "^20.x",
      "@types/supertest": "^2.x",
      "@typescript-eslint/eslint-plugin": "^6.x",
      "@typescript-eslint/parser": "^6.x",
      "eslint": "^8.x",
      "jest": "^29.x",
      "nodemon": "^3.x",
      "supertest": "^6.x",
      "testcafe": "^3.7.2",
      "ts-jest": "^29.x",
      "ts-node": "^10.x",
      "typescript": "^5.x"
   }
}
