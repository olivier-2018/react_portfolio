{
   "name": "portfolio-server",
   "version": "1.0.0",
   "description": "portfolio application",
   "main": "src/app.ts",
   "scripts": {
      "stamp": "sed -i \"s/^VITE_GIT_COMMIT_DATE=.*/VITE_GIT_COMMIT_DATE=\\\"$(git log -1 --format=%cd --date=iso-strict)\\\"/\" .env",
      "test": "jest",
      "lint": "eslint . --ext .ts",
      "build:client": "cd client && npm run build",
      "build:serve": "npm run build:client && npm run start:prod",
      "start:prod": "NODE_ENV=production node dist/app.js",
      "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
      "dev:backend": "cd . && NODE_ENV=development nodemon --exec ts-node src/app.ts",
      "dev:frontend": "cd client && npm run dev",
      "docker:build": "docker build -t portfolio:dev .",
      "docker:up": "docker compose -f docker-compose.local.yml up",
      "docker:down": "docker compose -f docker-compose.local.yml down",
      "docker:logs": "docker compose -f docker-compose.local.yml logs -f"
   },
   "dependencies": {
      "@supabase/supabase-js": "^2.x",
      "cors": "^2.8.5",
      "dotenv": "^16.x",
      "express": "^4.x",
      "express-validator": "^7.x",
      "helmet": "^7.x",
      "morgan": "^1.x",
      "winston": "^3.17.0"
   },
   "devDependencies": {
      "@playwright/test": "^1.54.2",
      "@types/cors": "^2.x",
      "@types/express": "^4.x",
      "@types/jest": "^29.x",
      "@types/morgan": "^1.x",
      "@types/node": "^20.x",
      "@types/supertest": "^2.x",
      "@typescript-eslint/eslint-plugin": "^6.x",
      "@typescript-eslint/parser": "^6.x",
      "concurrently": "^9.2.0",
      "eslint": "^8.x",
      "jest": "^29.x",
      "nodemon": "^3.1.10",
      "supertest": "^6.x",
      "testcafe": "^3.7.2",
      "ts-jest": "^29.x",
      "ts-node": "^10.x",
      "tsup": "^8.5.0",
      "typescript": "^5.x"
   }
}
