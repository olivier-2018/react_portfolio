# .env sample file

# Set the environment to production or development
# Note: production build mode has more secure settings and disables some development features.
NODE_ENV=production

# Last git commit date
# This is automatically updated by the build script
VITE_GIT_COMMIT_DATE="2025-12-01T00:0:00+00:00"

# Microsoft Copilot Direct Line Secret & Studio Agent URL
VITE_COPILOT_DIRECTLINE_SECRET=your_direct_line_secret_here# Copilot Studio Agent Configuration
VITE_COPILOT_AGENT_URL=your_copilot_agent_url_here

# Google reCAPTCHA
# Get your reCAPTCHA keys from https://www.google.com/recaptcha/admin/create
# VITE_USE_RECAPTCHA: Set to "true" to enable reCAPTCHA validation in production (dev mode always skips)
VITE_USE_RECAPTCHA=false
VITE_RECAPTCHA_SITE_KEY=<your_site_key_here>
VITE_RECAPTCHA_SECRET_KEY=<your_secret_key_here>

# Email Configuration
# Get your EmailJS service ID from https://dashboard.emailjs.com/admin/account
VITE_EMAILJS_SERVICE_ID=<your_service_id_here>
VITE_EMAILJS_TEMPLATE_ID=<your_template_id_here>
VITE_EMAILJS_PUBLIC_KEY=<your_public_key_here>

# DB selection - one of {supabase (default), local}
VITE_DB_SELECT=<supabase|local>

# Supabase 
VITE_SUPABASE_URL=<supabase URL>
VITE_SUPABASE_ANON_KEY=<your key>

# Postgress
VITE_POSTGRES_USER=<username>
VITE_POSTGRES_PASSWORD=<password>
VITE_POSTGRES_DB=<your postgres DB name>
VITE_POSTGRES_HOST=<host>
VITE_POSTGRES_PORT=<exposed port on host>

# API Configuration
VITE_API_PREFIX=/api/v1

# Backend Configuration
# Dev: http://localhost (Vite proxy or direct localhost calls)
# VPS: http://portfolio-backend (Docker DNS in docker network)
# Note: overwritten to http://localhost in Dev Mode
VITE_BACKEND_URL=http://portfolio-backend
VITE_BACKEND_PORT=3003

# Frontend Development (dev environment only)
# Used by 'npm run dev' to run Vite dev server on this port
VITE_FRONTEND_PORT=5173

# ============================================================================
# CORS Configuration (Backend)
# ============================================================================
# Controls which origins can make API requests to the backend
# Dev: http://localhost:5173 (Vite dev server on localhost)
# VPS: http://portfolio-frontend (Docker service name in docker network)
CORS_ORIGIN=http://localhost:5173,http://portfolio-frontend:5173

